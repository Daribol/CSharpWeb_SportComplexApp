@using SportComplexApp.Web.ViewModels.Sport
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<AllSportsViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="container mt-4">
    <h2 class="mb-4 text-center" style="color:#00ffc8;">@Localizer["Heading"]</h2>

    <form method="get" asp-controller="Sport" asp-action="All" class="mb-4">
        <div class="row g-3 align-items-end">
            <div class="col-md-3">
                <label for="searchQuery" class="form-label text-light">@Localizer["SearchName"]</label>
                <div class="input-group neon-input">
                    <span class="input-group-text neon-icon"><i class="bi bi-search"></i></span>
                    <input type="text" name="searchQuery" id="searchQuery" class="form-control" placeholder="@Localizer["SearchPlaceholder"]" value="@Context.Request.Query["searchQuery"]" />
                </div>
            </div>

            <div class="col-md-2">
                <label for="minDuration" class="form-label text-light">@Localizer["MinDuration"]</label>
                <div class="input-group neon-input">
                    <span class="input-group-text neon-icon"><i class="bi bi-hourglass-split"></i></span>
                    <input type="number" name="minDuration" id="minDuration" class="form-control" value="@Context.Request.Query["minDuration"]" />
                </div>
            </div>

            <div class="col-md-2">
                <label for="maxDuration" class="form-label text-light">@Localizer["MaxDuration"]</label>
                <div class="input-group neon-input">
                    <span class="input-group-text neon-icon"><i class="bi bi-hourglass"></i></span>
                    <input type="number" name="maxDuration" id="maxDuration" class="form-control" value="@Context.Request.Query["maxDuration"]" />
                </div>
            </div>

            <div class="col-md-3">
                <label for="sortBy" class="form-label text-light">@Localizer["SortBy"]</label>
                <div class="input-group neon-input">
                    <span class="input-group-text neon-icon"><i class="bi bi-sort-down"></i></span>
                    <select name="sortBy" id="sortBy" class="form-select">
                        <option value="">@Localizer["SortDefault"]</option>
                        <option value="name_asc" selected="@(Context.Request.Query["sortBy"] == "name_asc")">@Localizer["SortNameAsc"]</option>
                        <option value="name_desc" selected="@(Context.Request.Query["sortBy"] == "name_desc")">@Localizer["SortNameDesc"]</option>
                        <option value="duration_asc" selected="@(Context.Request.Query["sortBy"] == "duration_asc")">@Localizer["SortDurationAsc"]</option>
                        <option value="duration_desc" selected="@(Context.Request.Query["sortBy"] == "duration_desc")">@Localizer["SortDurationDesc"]</option>
                    </select>
                </div>
            </div>

            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-outline-neon">
                    <i class="bi bi-funnel-fill"></i> @Localizer["BtnFilter"]
                </button>
            </div>
        </div>

        <div class="mt-2 d-flex justify-content-end">
            <a asp-controller="Sport" asp-action="All" class="btn btn-outline-neon btn-sm">
                <i class="bi bi-x-circle"></i> @Localizer["BtnClear"]
            </a>
        </div>
    </form>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            <i class="bi bi-info-circle-fill me-2"></i>@Localizer["NoSportsMsg"]
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var sport in Model)
            {
                <div class="col">
                    <div class="card card-dark hover h-100 border-0">
                        <div class="cover ratio ratio-16x9" style="background-image:url('@sport.ImageUrl');"></div>
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-2">@sport.Name</h5>
                            <p class="text-muted mb-1"><strong>@Localizer["LabelFacility"]</strong> @sport.Facility</p>
                            <p class="text-muted mb-1"><strong>@Localizer["LabelPrice"]</strong> @sport.Price.ToString("F2") @Localizer["Currency"]</p>
                            <p class="text-muted mb-3"><strong>@Localizer["LabelDuration"]</strong> @sport.Duration @Localizer["Minutes"]</p>

                            <div class="mt-auto d-flex gap-2">
                                <a asp-action="Reserve" asp-route-id="@sport.Id" class="btn btn-neon w-100">
                                    <i class="bi bi-calendar-check"></i> @Localizer["BtnReserve"]
                                </a>
                                <a asp-controller="Trainer" asp-action="All" asp-route-sportId="@sport.Id" class="btn btn-outline-neon w-100">
                                    <i class="bi bi-person-lines-fill"></i> @Localizer["BtnTrainers"]
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-5 mb-4">
        <ul class="pagination sc-pagination justify-content-center gap-2">
            
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-minDuration="@ViewBag.MinDuration"
                       asp-route-maxDuration="@ViewBag.MaxDuration"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-trainerId="@ViewBag.TrainerId"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                    <i class="bi bi-chevron-left small me-1"></i> @Localizer["Previous"]
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link rounded-circle shadow-sm d-flex align-items-center justify-content-center"
                           style="width: 40px; height: 40px;"
                           asp-action="All"
                           asp-route-searchQuery="@ViewBag.SearchQuery"
                           asp-route-minDuration="@ViewBag.MinDuration"
                           asp-route-maxDuration="@ViewBag.MaxDuration"
                           asp-route-sortBy="@ViewBag.SortBy"
                           asp-route-trainerId="@ViewBag.TrainerId"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-minDuration="@ViewBag.MinDuration"
                       asp-route-maxDuration="@ViewBag.MaxDuration"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-trainerId="@ViewBag.TrainerId"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                    @Localizer["Next"] <i class="bi bi-chevron-right small ms-1"></i>
                </a>
            </li>
            
        </ul>
    </nav>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}