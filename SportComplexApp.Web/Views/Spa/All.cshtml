@using SportComplexApp.Web.ViewModels.Spa
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model PaginationSpaServiceViewModel

@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="container mt-4">
    <h2 class="mb-3 text-center" style="color:#00ffc8;">@Localizer["AvailableSpa"]</h2>
    <hr class="mb-4" style="border-color: rgba(255,255,255,.08);" />

    <div class="card card-dark border-0 shadow-sm mb-4">
        <div class="card-body">
            <form method="get" asp-controller="Spa" asp-action="All" class="mb-2">
                <div class="row g-3 align-items-end">
                    <div class="col-md-3">
                        <label for="searchQuery" class="form-label">@Localizer["SearchServices"]</label>
                        <div class="input-group neon-input">
                            <span class="input-group-text neon-icon"><i class="bi bi-search"></i></span>
                            <input type="text" name="searchQuery" id="searchQuery" class="form-control"
                                   placeholder="@Localizer["SearchPlaceholder"]"
                                   value="@Model.SearchQuery" />
                        </div>
                    </div>

                    <div class="col-md-2">
                        <label for="minDuration" class="form-label">@Localizer["MinDuration"]</label>
                        <div class="input-group neon-input">
                            <span class="input-group-text neon-icon"><i class="bi bi-hourglass-split"></i></span>
                            <input type="number" name="minDuration" id="minDuration" class="form-control"
                                   value="@(Model.MinDuration?.ToString())" />
                        </div>
                    </div>

                    <div class="col-md-2">
                        <label for="maxDuration" class="form-label">@Localizer["MaxDuration"]</label>
                        <div class="input-group neon-input">
                            <span class="input-group-text neon-icon"><i class="bi bi-hourglass"></i></span>
                            <input type="number" name="maxDuration" id="maxDuration" class="form-control"
                                   value="@(Model.MaxDuration?.ToString())" />
                        </div>
                    </div>
                    
                    <div class="col-md-3">
                        <label for="sortBy" class="form-label">@Localizer["SortBy"]</label>
                        <div class="input-group neon-input">
                            <span class="input-group-text neon-icon"><i class="bi bi-sort-down"></i></span>
                            <select name="sortBy" id="sortBy" class="form-select">
                                <option value="">@Localizer["SortDefault"]</option>
                                <option value="name_asc" selected="@(Model.SortBy == "name_asc")">@Localizer["SortNameAsc"]</option>
                                <option value="name_desc" selected="@(Model.SortBy == "name_desc")">@Localizer["SortNameDesc"]</option>
                                <option value="price_asc" selected="@(Model.SortBy == "price_asc")">@Localizer["SortPriceAsc"]</option>
                                <option value="price_desc" selected="@(Model.SortBy == "price_desc")">@Localizer["SortPriceDesc"]</option>
                            </select>
                        </div>
                    </div>

                    <div class="col-md-2 d-grid">
                        <button type="submit" class="btn btn-outline-neon">
                            <i class="bi bi-funnel-fill"></i> @Localizer["BtnFilter"]
                        </button>
                    </div>
                </div>
            </form>

            <div class="d-flex justify-content-end">
                <a asp-controller="Spa" asp-action="All" class="btn btn-outline-neon btn-sm">
                    <i class="bi bi-x-circle"></i> @Localizer["BtnClear"]
                </a>
            </div>
        </div>
    </div>

    @if (Model.SpaServices == null || !Model.SpaServices.Any())
    {
        <div class="card card-dark p-5 text-center border-0">
            <div class="display-6 mb-2">💆‍♀️</div>
            <h5 class="mb-1">@Localizer["NoSpaTitle"]</h5>
            <p class="text-muted mb-0">@Localizer["NoSpaDesc"]</p>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var spa in Model.SpaServices)
            {
                <div class="col">
                    <div class="card card-dark hover h-100 border-0">
                        @if (!string.IsNullOrWhiteSpace(spa.ImageUrl))
                        {
                            <div class="cover ratio ratio-16x9" style="background-image:url('@spa.ImageUrl');"></div>
                        }
                        else
                        {
                            <div class="cover cover--placeholder ratio ratio-16x9 d-flex align-items-center justify-content-center">
                                <i class="bi bi-flower3 display-6 text-muted"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-start justify-content-between mb-2">
                                <h5 class="card-title mb-0">@spa.Name</h5>
                                <span class="badge badge-sport">@spa.Duration @Localizer["Minutes"]</span>
                            </div>

                            @if (!string.IsNullOrWhiteSpace(spa.Description))
                            {
                                <p class="text-muted clamp-3 mb-3">@spa.Description</p>
                            }

                            <div class="d-flex align-items-center justify-content-between mt-auto">
                                <span class="price-tag">@spa.Price.ToString("0.##") @Localizer["Currency"]</span>
                                <div class="d-flex gap-2">
                                    <a asp-controller="Spa" asp-action="Reserve" asp-route-id="@spa.Id" class="btn btn-neon btn-sm">
                                        <i class="bi bi-calendar-check me-1"></i> @Localizer["BtnReserve"]
                                    </a>
                                    <a asp-action="Details" asp-route-id="@spa.Id" class="btn btn-outline-neon btn-sm">
                                        <i class="bi bi-info-circle me-1"></i> @Localizer["BtnDetails"]
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-5 mb-4">
        <ul class="pagination sc-pagination justify-content-center gap-2">
            
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-minDuration="@ViewBag.MinDuration"
                       asp-route-maxDuration="@ViewBag.MaxDuration"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                    <i class="bi bi-chevron-left small me-1"></i> @Localizer["Previous"]
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link rounded-circle shadow-sm d-flex align-items-center justify-content-center"
                           style="width: 40px; height: 40px;"
                           asp-action="All"
                           asp-route-searchQuery="@ViewBag.SearchQuery"
                           asp-route-minDuration="@ViewBag.MinDuration"
                           asp-route-maxDuration="@ViewBag.MaxDuration"
                           asp-route-sortBy="@ViewBag.SortBy"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-minDuration="@ViewBag.MinDuration"
                       asp-route-maxDuration="@ViewBag.MaxDuration"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                    @Localizer["Next"] <i class="bi bi-chevron-right small ms-1"></i>
                </a>
            </li>
            
        </ul>
    </nav>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}