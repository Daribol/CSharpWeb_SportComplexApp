@model IEnumerable<SportComplexApp.Web.ViewModels.Trainer.TrainerMasterViewModel>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

<div class="container mt-5">
    <h2 class="mb-4 text-center" style="color:#00ffc8;">@Localizer["TrainersPageHeader"]</h2>

    <div class="table-responsive shadow-sm">
        <table class="table align-middle mb-0 sc-table" style="border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="width: 50px;"></th>
                    <th>@Localizer["ColumnTrainerName"]</th>
                    <th>@Localizer["ColumnSpecialty"]</th>
                    <th>@Localizer["ColumnReservationsCount"]</th>
                    <th class="text-center">@Localizer["ColumnActions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var trainer in Model)
                {
                    <tr data-bs-toggle="collapse" data-bs-target="#trainer-@trainer.Id" aria-expanded="false" style="cursor: pointer;">
                        <td class="text-center text-info">
                            <i class="bi bi-chevron-down"></i>
                        </td>
                        <td class="fw-semibold">@trainer.FullName</td>
                        <td><span class="text-muted">@trainer.SpecialtySport</span></td>
                        <td><span class="badge sc-badge-soft">@trainer.Reservations.Count()</span></td>
                        <td class="text-center">
                            <a asp-controller="Reservation" asp-action="Book" asp-route-trainerId="@trainer.Id" class="btn btn-sm btn-outline-neon" onclick="event.stopPropagation();">
                                @Localizer["ButtonBookSession"]
                            </a>
                        </td>
                    </tr>

                    <tr id="trainer-@trainer.Id" class="collapse" style="background-color: #0a0a0a;">
                        <td colspan="5" class="p-4 border-bottom border-info">
                            
                            <h6 class="text-muted mb-3">
                                <i class="bi bi-calendar-event me-2"></i>
                                @Localizer["ReservationsForHeader"] @trainer.FullName
                            </h6>
                            
                            @if (trainer.Reservations.Any())
                            {
                                <table class="table table-sm table-dark table-borderless mb-0 w-100 shadow-sm" style="border-radius: 8px; overflow: hidden;">
                                    <thead style="background: rgba(0, 255, 200, 0.05);">
                                        <tr>
                                            <th>@Localizer["SubColumnAvailability"]</th>
                                            <th>@Localizer["SubColumnDate"]</th>
                                            <th>@Localizer["SubColumnTime"]</th>
                                            <th class="text-center">@Localizer["SubColumnStatus"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var res in trainer.Reservations.OrderByDescending(r => r.ReservationDate))
                                        {
                                            <tr>
                                                <td>@res.CustomerName</td>
                                                <td>@res.ReservationDate</td>
                                                <td>@res.TimeSlot</td>
                                                <td class="text-center">
                                                    @if (res.Status == "Upcoming")
                                                    {
                                                        <span class="badge bg-success text-dark fw-bold">@res.Status</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-secondary">@res.Status</span>
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted my-2">@Localizer["NoReservationsAvailable"]</div>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <style>
        tr[data-bs-toggle="collapse"] i.bi-chevron-down {
            transition: transform 0.3s ease;
            display: inline-block;
        }

        tr[data-bs-toggle="collapse"][aria-expanded="true"] i.bi-chevron-down {
            transform: rotate(180deg);
        }
        tr[data-bs-toggle="collapse"] {
            user-select: none;
        }
    </style>
}