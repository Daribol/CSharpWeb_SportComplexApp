@using SportComplexApp.Web.ViewModels.Trainer
@model IEnumerable<TrainerReservationViewModel>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = "My Schedule";
}

<link rel="stylesheet" href="~/css/neon-theme.css" asp-append-version="true" />

<div class="container mt-4">
    
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div id="trainer-calendar-container">
        <partial name="_TrainerReservationsCalendarPartial" model="Model" />
    </div>

</div>

<div class="modal fade" id="customConfirmModal" tabindex="-1" aria-labelledby="customConfirmModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark border-secondary border-opacity-50 shadow-lg" style="border-radius: 1rem;">
            
            <div class="modal-header border-secondary border-opacity-25">
                <h5 class="modal-title fw-bold text-danger" id="customConfirmModalLabel">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i> @Localizer["CancelTitle"] </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            
            <div class="modal-body text-light fs-5 py-4">
                @Localizer["ConfirmCancelMsg"] </div>
            
            <div class="modal-footer border-secondary border-opacity-25">
                <button type="button" class="btn btn-outline-light rounded-pill px-4" data-bs-dismiss="modal">
                    @Localizer["BtnClose"] </button>
                
                <form asp-action="CancelReservation" asp-controller="Trainer" method="post" class="m-0 p-0">
                    <input type="hidden" name="reservationId" id="modalReservationIdInput" value="" />
                    <button type="submit" class="btn btn-danger rounded-pill px-4 shadow">
                        <i class="bi bi-trash3-fill me-1"></i> @Localizer["BtnConfirmCancel"] </button>
                </form>
            </div>
            
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    
    <script>
        function loadTrainerCalendar(month, year) {
            const container = document.getElementById('trainer-calendar-container');
            container.style.opacity = '0.5';

            fetch(`/Trainer/GetReservationsPartial?month=${month}&year=${year}`)
                .then(response => {
                    if (!response.ok) throw new Error('Грешка при зареждане на графика');
                    return response.text();
                })
                .then(html => {
                    container.innerHTML = html;
                    container.style.opacity = '1';
                })
                .catch(error => {
                    console.error('Error:', error);
                    container.style.opacity = '1';
                });
        }

        document.addEventListener('DOMContentLoaded', function () {
            var confirmModal = document.getElementById('customConfirmModal');
            if(confirmModal) {
                confirmModal.addEventListener('show.bs.modal', function (event) {
                    var button = event.relatedTarget;
                    var resId = button.getAttribute('data-reservation-id');
                    var hiddenInput = document.getElementById('modalReservationIdInput');
                    hiddenInput.value = resId;
                });
            }
        });
    </script>
    
    <style>
        .row-cols-7 > * { flex: 0 0 auto; width: 14.2857142857%; }
        .style-scrollbar::-webkit-scrollbar { width: 4px; }
        .style-scrollbar::-webkit-scrollbar-thumb { background-color: rgba(0, 255, 200, 0.3); border-radius: 4px; }

        .day-card { transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275), box-shadow 0.2s ease, border-color 0.2s ease; z-index: 1; position: relative; }
        .day-card.has-events:hover { transform: scale(1.5); z-index: 100; box-shadow: 0 20px 40px rgba(0,0,0,0.95), 0 0 20px rgba(0, 255, 200, 0.4) !important; background-color: #161a1a !important; border-color: rgba(0, 255, 200, 0.8) !important; cursor: pointer; }
        .day-card.has-events:hover .p-1.overflow-auto { max-height: none !important; overflow: visible !important; }
        .day-card.has-events:hover .text-truncate { white-space: normal !important; word-break: break-word; }
    </style>
}