@using Microsoft.AspNetCore.Identity
@using SportComplexApp.Data.Models
@using Microsoft.AspNetCore.Mvc.Localization

@inject IViewLocalizer Localizer
@inject SignInManager<Client> SignInManager
@inject UserManager<Client> UserManager

@if (SignInManager.IsSignedIn(User))
{
    var user = await UserManager.GetUserAsync(User);

    <div class="d-flex align-items-center gap-2">
        <a class="text-light text-decoration-none d-flex align-items-center" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            <i class="bi bi-person-circle fs-5" style="color: #00ffc8;"></i>
            <span class="ms-2 text-truncate" style="max-width: 120px; font-size: 0.9rem;">
                @Localizer["Hello"], @(user?.FirstName ?? User.Identity?.Name)!
            </span>
        </a>
        
        <form class="form-inline m-0 ms-1 ms-md-2" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
            <button type="submit" class="btn btn-link text-danger p-0 d-flex align-items-center text-decoration-none" title="@Localizer["Logout"]">
                <i class="bi bi-box-arrow-right fs-5"></i>
                <span class="d-none d-md-inline ms-1">@Localizer["Logout"]</span>
            </button>
        </form>
    </div>
}
else
{
    <div class="d-flex align-items-center gap-2 gap-md-3">
        <a class="text-light text-decoration-none d-flex align-items-center" asp-area="Identity" asp-page="/Account/Register" title="@Localizer["Register"]">
            <i class="bi bi-person-plus fs-5"></i>
            <span class="ms-1" style="font-size: 0.9rem;">@Localizer["Register"]</span>
        </a>
        
        <a class="text-light text-decoration-none d-flex align-items-center" asp-area="Identity" asp-page="/Account/Login" title="@Localizer["Login"]">
            <i class="bi bi-box-arrow-in-right fs-5" style="color: #00ffc8;"></i>
            <span class="ms-1" style="font-size: 0.9rem;">@Localizer["Login"]</span>
        </a>
    </div>
}