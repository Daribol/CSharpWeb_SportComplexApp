@using SportComplexApp.Web.ViewModels.Tournament
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<TournamentViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
    var now = DateTime.Now;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0" style="color:#00ffc8;">@Localizer["Heading"]</h2>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card card-dark border-0 shadow-lg rounded-4 mb-4">
    <div class="card-body">
        <form method="get" asp-controller="Tournament" asp-action="All" class="mb-2">
            <div class="row g-3 align-items-end">
                <div class="col-md-3">
                    <label for="searchQuery" class="form-label text-light">@Localizer["SearchName"]</label>
                    <div class="input-group neon-input">
                        <span class="input-group-text neon-icon"><i class="bi bi-search"></i></span>
                        <input type="text" name="searchQuery" id="searchQuery" class="form-control" placeholder="@Localizer["SearchPlaceholder"]" value="@Context.Request.Query["searchQuery"]" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label for="sport" class="form-label text-light">@Localizer["FilterSport"]</label>
                    <div class="input-group neon-input">
                        <span class="input-group-text neon-icon"><i class="bi bi-dribbble"></i></span>
                        <input type="text" name="sport" id="sport" class="form-control" placeholder="@Localizer["SportPlaceholder"]" value="@Context.Request.Query["sport"]" />
                    </div>
                </div>

                <div class="col-md-3">
                    <label for="sortBy" class="form-label text-light">@Localizer["SortBy"]</label>
                    <div class="input-group neon-input">
                        <span class="input-group-text neon-icon"><i class="bi bi-sort-down"></i></span>
                        <select name="sortBy" id="sortBy" class="form-select">
                            <option value="">@Localizer["SortDefault"]</option>
                            <option value="name_asc" selected="@(Context.Request.Query["sortBy"] == "name_asc")">@Localizer["SortNameAsc"]</option>
                            <option value="name_desc" selected="@(Context.Request.Query["sortBy"] == "name_desc")">@Localizer["SortNameDesc"]</option>
                            <option value="date_asc" selected="@(Context.Request.Query["sortBy"] == "date_asc")">@Localizer["SortDateAsc"]</option>
                            <option value="date_desc" selected="@(Context.Request.Query["sortBy"] == "date_desc")">@Localizer["SortDateDesc"]</option>
                        </select>
                    </div>
                </div>

                <div class="col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-outline-neon flex-grow-1">
                        <i class="bi bi-funnel-fill"></i> @Localizer["BtnFilter"]
                    </button>
                    <a asp-action="All" class="btn btn-outline-neon">
                        <i class="bi bi-x-circle"></i> @Localizer["BtnClear"]
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
    @foreach (var t in Model)
    {
        var isFinished = t.EndDate < now;
        var isUpcoming = t.StartDate > now;
        
        var statusKey = isFinished ? "StatusFinished" : (isUpcoming ? "StatusUpcoming" : "StatusOngoing");
        var badgeClass = isFinished ? "badge-soft" : (isUpcoming ? "badge-sport" : "bg-success");
        
        var durationDays = Math.Max(1, (t.EndDate.Date - t.StartDate.Date).Days + 1);
        var hasImg = !string.IsNullOrWhiteSpace(t.ImageUrl);

        <div class="col">
            <div class="card card-dark @(isFinished ? "" : "hover") h-100 border-0 rounded-4" style="@(isFinished ? "filter: grayscale(100%); opacity: 0.65;" : "")">
                
                @if (hasImg)
                {
                    <div class="cover" style="height: 200px; background-image:url('@t.ImageUrl'); background-size: cover; background-position: center; border-radius: 1rem 1rem 0 0;"></div>
                }
                else
                {
                    <div class="cover cover--placeholder ratio ratio-16x9 d-flex align-items-center justify-content-center bg-dark border-bottom border-secondary border-opacity-25" style="border-radius: 1rem 1rem 0 0;">
                        <i class="bi bi-trophy display-1 text-light-50"></i>
                    </div>
                }

                <div class="card-body d-flex flex-column">
                    <div class="d-flex align-items-start justify-content-between mb-2">
                        <h5 class="card-title mb-0 text-white">@t.Name</h5>
                        <span class="badge @badgeClass">
                            @Localizer[statusKey]
                        </span>
                    </div>

                    <div class="mb-3">
                        <span class="badge badge-sport me-1">@t.Sport</span>
                        <span class="badge badge-soft">@durationDays @Localizer["DaysShort"]</span>
                    </div>

                    <ul class="list-unstyled small text-muted mb-3">
                        <li><i class="bi bi-calendar-event text-info me-1"></i> @t.StartDate.ToString("dd MMM yyyy") → @t.EndDate.ToString("dd MMM yyyy")</li>
                    </ul>

                    @if (!string.IsNullOrWhiteSpace(t.Description))
                    {
                        <p class="text-light-50 small clamp-3 mb-0">@t.Description</p>
                    }

                    <div class="mt-auto pt-3">
                        @if (User.IsInRole("Trainer"))
                        {
                            <button class="btn btn-outline-secondary btn-sm w-100" disabled>
                                @Localizer["MsgTrainerCannotRegister"]
                            </button>
                        }
                        else if (isFinished)
                        {
                            <button class="btn w-100 text-light-50 border-0 disabled" style="background-color: #222; cursor: not-allowed;">
                                <i class="bi bi-lock-fill me-1"></i> @Localizer["StatusFinished"]
                            </button>
                        }
                        else
                        {
                            <form asp-action="Register" asp-route-id="@t.Id" method="post">
                                <button type="submit" class="btn btn-neon w-100">
                                    <i class="bi bi-pencil-square me-1"></i> @Localizer["BtnRegister"]
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-5 mb-4">
        <ul class="pagination sc-pagination justify-content-center gap-2">
            
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-sport="@ViewBag.Sport"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                    <i class="bi bi-chevron-left small me-1"></i> @Localizer["Previous"]
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link rounded-circle shadow-sm d-flex align-items-center justify-content-center"
                           style="width: 40px; height: 40px;"
                           asp-action="All"
                           asp-route-searchQuery="@ViewBag.SearchQuery"
                           asp-route-sport="@ViewBag.Sport"
                           asp-route-sortBy="@ViewBag.SortBy"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-sport="@ViewBag.Sport"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                    @Localizer["Next"] <i class="bi bi-chevron-right small ms-1"></i>
                </a>
            </li>
            
        </ul>
    </nav>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}