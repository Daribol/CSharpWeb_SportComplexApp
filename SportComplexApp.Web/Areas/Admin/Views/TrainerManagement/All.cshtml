@using SportComplexApp.Web.ViewModels.Trainer
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<AllTrainersViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0" style="color:#00ffc8;">@Localizer["Heading"]</h2>
    <a asp-action="Add" class="btn btn-neon">
        <i class="bi bi-plus-circle me-1"></i> @Localizer["BtnAddTrainer"]
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" asp-action="All" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-5">
            <label for="query" class="form-label text-light">@Localizer["LabelSearch"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-search"></i></span>
                <input type="text" name="query" id="query" class="form-control" placeholder="@Localizer["PlaceholderSearch"]" value="@Context.Request.Query["query"]" />
            </div>
        </div>

        <div class="col-md-4">
            <label for="sortBy" class="form-label text-light">@Localizer["LabelSortBy"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-sort-down"></i></span>
                <select name="sortBy" id="sortBy" class="form-select">
                    <option value="">@Localizer["SortDefault"]</option>
                    <option value="name_asc" selected="@(Context.Request.Query["sortBy"] == "name_asc")">@Localizer["SortNameAsc"]</option>
                    <option value="name_desc" selected="@(Context.Request.Query["sortBy"] == "name_desc")">@Localizer["SortNameDesc"]</option>
                </select>
            </div>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-neon flex-grow-1">
                <i class="bi bi-funnel-fill"></i> @Localizer["BtnFilter"]
            </button>
            <a asp-action="All" class="btn btn-outline-neon">
                <i class="bi bi-x-circle"></i> @Localizer["BtnClear"]
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card card-dark text-center p-5 rounded-4 border-0">
        <div class="display-6 mb-2">🧑‍🏫</div>
        <h5 class="mb-1 text-light">@Localizer["EmptyTitle"]</h5>
        <p class="text-light-50 mb-3">@Localizer["EmptyDesc"]</p>
        <a asp-action="Add" class="btn btn-neon">
            <i class="bi bi-plus-circle"></i> @Localizer["BtnEmptyAdd"]
        </a>
    </div>
}
else
{
    <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4">
        @foreach (var t in Model)
        {
            <div class="col">
                <div class="card card-dark hover h-100 border-0">
                    @if (!string.IsNullOrWhiteSpace(t.ImageUrl))
                    {
                        <div class="cover ratio ratio-16x9" style="background-image:url('@t.ImageUrl');"></div>
                    }
                    else
                    {
                        <div class="cover cover--placeholder ratio ratio-16x9 d-flex align-items-center justify-content-center">
                            <i class="bi bi-person-bounding-box display-6 text-light-50"></i>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between mb-2">
                            <h5 class="card-title mb-0 text-white">@t.Name @t.LastName</h5>
                            <span class="badge badge-soft"><i class="bi bi-award me-1"></i> @Localizer["BadgeTrainer"]</span>
                        </div>

                        <div class="mb-3">
                            @if (t.Sports?.Any() == true)
                            {
                                foreach (var sport in t.Sports)
                                {
                                    <span class="badge badge-sport me-1 mb-1">@sport</span>
                                }
                            }
                            else
                            {
                                <span class="text-light-50">@Localizer["NoSpecialization"]</span>
                            }
                        </div>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-outline-neon btn-sm">
                                <i class="bi bi-pencil-square"></i> @Localizer["BtnEdit"]
                            </a>
                            <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-outline-neon btn-sm">
                                <i class="bi bi-trash3"></i> @Localizer["BtnDelete"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
}