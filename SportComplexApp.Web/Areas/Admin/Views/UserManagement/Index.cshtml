@using SportComplexApp.Web.ViewModels.Admin
@using Microsoft.AspNetCore.Mvc.Localization
@using Microsoft.Extensions.Localization
@using SportComplexApp.Common
@inject IViewLocalizer Localizer
@inject IStringLocalizer<SharedResource> SharedLocalizer
@model IEnumerable<AllUsersViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
}
@{
    bool isBg = System.Globalization.CultureInfo.CurrentCulture.Name.StartsWith("bg");

    string TranslateRole(string r) => r switch
    {
        "Admin" => isBg ? "Администратор" : "Admin",
        "Trainer" => isBg ? "Треньор" : "Trainer",
        "Client" => isBg ? "Клиент" : "Client",
        _ => r
    };
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0" style="color:#00ffc8;">@Localizer["Heading"]</h2>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="card card-dark text-center p-5 rounded-4 border-0">
        <div class="display-6 mb-2">👥</div>
        <h5 class="mb-1 text-light">@Localizer["EmptyTitle"]</h5>
        <p class="text-light-50 mb-0">@Localizer["EmptyDesc"]</p>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var user in Model)
        {
            <div class="card card-dark hover border-0 rounded-4 p-3 p-lg-4 d-flex flex-column flex-xl-row align-items-xl-center gap-4">
                
                <div class="d-flex align-items-center gap-3" style="min-width: 280px;">
                    <div class="bg-dark border border-secondary border-opacity-25 rounded-circle d-flex align-items-center justify-content-center flex-shrink-0" style="width: 50px; height: 50px;">
                        <i class="bi bi-person-fill text-light-50 fs-4"></i>
                    </div>
                    <div>
                        <h6 class="mb-1 text-white fw-bold">@user.Email</h6>
                        <span class="text-light-50 small">@user.FirstName @user.LastName</span>
                    </div>
                </div>

                <div class="d-flex flex-wrap gap-2 flex-grow-1 ms-xl-4 me-xl-4">
                    @if (user.Roles != null && user.Roles.Any())
                    {
                        @foreach (var role in user.Roles)
                        {
                            var badgeClass = role switch
                            {
                                "Admin" => "bg-danger",
                                "Trainer" => "bg-warning text-dark",
                                "Client" => "badge-sport",
                                _ => "badge-soft"
                            };

                            var iconClass = role switch
                            {
                                "Admin" => "bi-shield-lock",
                                "Trainer" => "bi-star",
                                "Client" => "bi-person",
                                _ => "bi-question-circle"
                            };

                            <span class="badge @badgeClass shadow-sm px-3 py-2 rounded-pill d-inline-flex align-items-center"
                                  style="max-width: 140px; white-space: nowrap;">
                                <i class="bi @iconClass flex-shrink-0"></i>
                                <span class="ms-2 text-truncate">@TranslateRole(role)</span>
                            </span>
                        }
                    }
                    else
                    {
                        <span class="text-light-50 small fst-italic">@Localizer["NoRoles"]</span>
                    }
                </div>

                <div class="d-flex flex-column flex-md-row align-items-md-center gap-2 mt-3 mt-xl-0 ms-xl-auto">
    
                    <form asp-action="AssignRole" method="post" class="d-flex gap-2">
                        <input type="hidden" name="userId" value="@user.Id" />
                        <select name="role" class="form-select form-select-sm bg-dark text-light border-secondary notranslate" translate="no">
                            <option value="Admin">@TranslateRole("Admin")</option>
                            <option value="Client">@TranslateRole("Client")</option>
                            <option value="Trainer">@TranslateRole("Trainer")</option>
                        </select>
                        <button type="submit" class="btn btn-outline-neon btn-sm text-nowrap" title="@Localizer["BtnAssign"]">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </form>

                    @if (user.Roles != null && user.Roles.Any())
                    {
                        <form asp-action="RemoveRole" method="post" class="d-flex gap-2">
                            <input type="hidden" name="userId" value="@user.Id" />
                            <select name="role" class="form-select form-select-sm bg-dark text-light border-secondary notranslate" translate="no">
                                @foreach (var role in user.Roles)
                                {
                                    string safeEnglishRole = "Client";
                                    if (role.Contains("Admin") || role.Contains("Админ") || role.Contains("Администратор")) safeEnglishRole = "Admin";
                                    if (role.Contains("Trainer") || role.Contains("Треньор")) safeEnglishRole = "Trainer";

                                    <option value="@safeEnglishRole">@TranslateRole(safeEnglishRole)</option>
                                }
                            </select>
                            <button type="submit" class="btn btn-outline-warning btn-sm text-nowrap" title="@Localizer["BtnRemove"]">
                                <i class="bi bi-dash-lg"></i>
                            </button>
                        </form>
                    }

                    <a asp-action="DeleteUser" asp-route-id="@user.Id" class="btn btn-outline-danger btn-sm text-nowrap ms-md-2" title="@Localizer["BtnDelete"]">
                        <i class="bi bi-trash3"></i>
                    </a>
                </div>
                
            </div>
        }
    </div>
}

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-5 mb-4">
        <ul class="pagination sc-pagination justify-content-center gap-2">
            
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                    <i class="bi bi-chevron-left small me-1"></i> @Localizer["Previous"]
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link rounded-circle shadow-sm d-flex align-items-center justify-content-center"
                           style="width: 40px; height: 40px;"
                           asp-action="Index"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                    @Localizer["Next"] <i class="bi bi-chevron-right small ms-1"></i>
                </a>
            </li>
            
        </ul>
    </nav>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
}