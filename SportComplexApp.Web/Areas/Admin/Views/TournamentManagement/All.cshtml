@using SportComplexApp.Web.ViewModels.Tournament
@using Microsoft.AspNetCore.Mvc.Localization
@using System
@inject IViewLocalizer Localizer
@model IEnumerable<TournamentViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
    var now = DateTime.Now;
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0" style="color:#00ffc8;">@Localizer["Heading"]</h2>
    <a asp-action="Add" class="btn btn-neon">
        <i class="bi bi-plus-circle me-1"></i> @Localizer["BtnCreateTournament"]
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" asp-action="All" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label for="searchQuery" class="form-label text-light">@Localizer["LabelSearchName"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-search"></i></span>
                <input type="text" name="searchQuery" id="searchQuery" class="form-control" placeholder="@Localizer["PlaceholderSearch"]" value="@Context.Request.Query["searchQuery"]" />
            </div>
        </div>

        <div class="col-md-3">
            <label for="sport" class="form-label text-light">@Localizer["LabelFilterSport"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-dribbble"></i></span>
                <input type="text" name="sport" id="sport" class="form-control" placeholder="@Localizer["PlaceholderSport"]" value="@Context.Request.Query["sport"]" />
            </div>
        </div>

        <div class="col-md-3">
            <label for="sortBy" class="form-label text-light">@Localizer["LabelSortBy"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-sort-down"></i></span>
                <select name="sortBy" id="sortBy" class="form-select">
                    <option value="">@Localizer["SortDefault"]</option>
                    <option value="name_asc" selected="@(Context.Request.Query["sortBy"] == "name_asc")">@Localizer["SortNameAsc"]</option>
                    <option value="name_desc" selected="@(Context.Request.Query["sortBy"] == "name_desc")">@Localizer["SortNameDesc"]</option>
                    <option value="date_asc" selected="@(Context.Request.Query["sortBy"] == "date_asc")">@Localizer["SortDateAsc"]</option>
                    <option value="date_desc" selected="@(Context.Request.Query["sortBy"] == "date_desc")">@Localizer["SortDateDesc"]</option>
                </select>
            </div>
        </div>

        <div class="col-md-3 d-flex gap-2">
            <button type="submit" class="btn btn-outline-neon flex-grow-1">
                <i class="bi bi-funnel-fill"></i> @Localizer["BtnFilter"]
            </button>
            <a asp-action="All" class="btn btn-outline-neon">
                <i class="bi bi-x-circle"></i> @Localizer["BtnClear"]
            </a>
        </div>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card card-dark text-center p-5 rounded-4 border-0">
        <div class="display-6 mb-2">🏆</div>
        <h5 class="mb-1 text-light">@Localizer["EmptyTitle"]</h5>
        <p class="text-light-50 mb-3">@Localizer["EmptyDesc"]</p>
        <a asp-action="Add" class="btn btn-neon">
            <i class="bi bi-plus-circle"></i> @Localizer["BtnCreateTournament"]
        </a>
    </div>
}
else
{
    <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4">
        @foreach (var t in Model)
        {
            var isFinished = t.EndDate < now;
            var isUpcoming = t.StartDate > now;
            var isOngoing = !isFinished && !isUpcoming;
            
            var durationDays = Math.Max(1, (t.EndDate.Date - t.StartDate.Date).Days + 1);
            var hasImg = !string.IsNullOrWhiteSpace(t.ImageUrl);

            <div class="col">
                <div class="card card-dark hover h-100 border-0 rounded-4">
                    
                    @if (hasImg)
                    {
                        <img src="@t.ImageUrl" class="card-img-top" alt="@t.Name" style="height: 180px; object-fit: cover; border-radius: 1rem 1rem 0 0;" />
                    }
                    else
                    {
                        <div class="cover cover--placeholder ratio ratio-16x9 d-flex align-items-center justify-content-center bg-dark border-bottom border-secondary border-opacity-25" style="border-radius: 1rem 1rem 0 0;">
                            <i class="bi bi-trophy-fill display-6 text-light-50"></i>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <div class="d-flex align-items-start justify-content-between mb-2">
                            <h5 class="card-title mb-0 text-white clamp-3">@t.Name</h5>

                            @if (isUpcoming)
                            {
                                <span class="badge badge-sport">
                                    <i class="bi bi-hourglass-split me-1"></i> @Localizer["StatusUpcoming"]
                                </span>
                            }
                            else if (isOngoing)
                            {
                                <span class="badge bg-success">
                                    <i class="bi bi-activity me-1"></i> @Localizer["StatusOngoing"]
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    <i class="bi bi-check2-circle me-1"></i> @Localizer["StatusFinished"]
                                </span>
                            }
                        </div>

                        <div class="mb-2">
                            <span class="badge badge-sport me-1">@t.Sport</span>
                            <span class="badge badge-soft">@durationDays @Localizer["DaysShort"]</span>
                        </div>

                        <ul class="list-unstyled small text-muted mb-3">
                            <li>
                                <i class="bi bi-calendar-event text-primary"></i>
                                @t.StartDate.ToString("dd MMM yyyy") → @t.EndDate.ToString("dd MMM yyyy")
                            </li>
                        </ul>
                        
                        <p class="text-light-50 clamp-3 mb-3">@t.Description</p>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@t.Id" class="btn btn-outline-neon btn-sm flex-grow-1">
                                <i class="bi bi-pencil-square"></i> @Localizer["BtnEdit"]
                            </a>
                            <a asp-action="Delete" asp-route-id="@t.Id" class="btn btn-outline-danger btn-sm flex-grow-1">
                                <i class="bi bi-trash3"></i> @Localizer["BtnDelete"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-5 mb-4">
        <ul class="pagination sc-pagination justify-content-center gap-2">
            
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-sport="@ViewBag.Sport"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                    <i class="bi bi-chevron-left small me-1"></i> @Localizer["Previous"]
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link rounded-circle shadow-sm d-flex align-items-center justify-content-center"
                           style="width: 40px; height: 40px;"
                           asp-action="All"
                           asp-route-searchQuery="@ViewBag.SearchQuery"
                           asp-route-sport="@ViewBag.Sport"
                           asp-route-sortBy="@ViewBag.SortBy"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-searchQuery="@ViewBag.SearchQuery"
                       asp-route-sport="@ViewBag.Sport"
                       asp-route-sortBy="@ViewBag.SortBy"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                    @Localizer["Next"] <i class="bi bi-chevron-right small ms-1"></i>
                </a>
            </li>
            
        </ul>
    </nav>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
}