@using SportComplexApp.Web.ViewModels.Report
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<SportReportViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="d-flex align-items-center justify-content-between mb-4 print-hide">
    <h2 class="mb-0" style="color:#00ffc8;">
        <i class="bi bi-graph-up-arrow me-2"></i>@Localizer["Heading"]
    </h2>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-neon">
            <i class="bi bi-printer me-1"></i> @Localizer["BtnPrint"]
        </button>
        <a asp-action="ExportSportReservationsCsv" class="btn btn-neon">
            <i class="bi bi-filetype-csv me-1"></i> @Localizer["BtnExport"]
        </a>
    </div>
</div>

<div class="card card-dark border-0 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover table-borderless align-middle mb-0 text-center">
                <thead style="border-bottom: 2px solid #00ffc8;">
                    <tr>
                        <th scope="col" class="text-start ps-4 py-3">@Localizer["ColSportName"]</th>
                        <th scope="col" class="py-3">@Localizer["ColTotalReservations"]</th>
                        <th scope="col" class="py-3">@Localizer["ColTotalVisitors"]</th>
                        <th scope="col" class="text-end pe-4 py-3">@Localizer["ColTotalRevenue"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted">
                                @Localizer["EmptyData"]
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var stat in Model)
                        {
                            <tr>
                                <td class="text-start ps-4 py-3 fw-bold text-light">@stat.SportName</td>
                                <td class="py-3 text-info">@stat.TotalReservations</td>
                                <td class="py-3 text-warning">@stat.TotalPeople <i class="bi bi-people-fill ms-1"></i></td>
                                <td class="text-end pe-4 py-3 text-success fw-bold">
                                    @stat.TotalRevenue.ToString("F2") @Localizer["Currency"]
                                </td>
                            </tr>
                        }
                        <tr style="border-top: 1px solid rgba(255,255,255,0.1);">
                            <td class="text-start ps-4 py-3 text-neon fw-bold">@Localizer["TotalLabel"]</td>
                            <td class="py-3 fw-bold text-info">@Model.Sum(x => x.TotalReservations)</td>
                            <td class="py-3 fw-bold text-warning">@Model.Sum(x => x.TotalPeople)</td>
                            <td class="text-end pe-4 py-3 text-success fw-bold display-6 fs-4">
                                @Model.Sum(x => x.TotalRevenue).ToString("F2") @Localizer["Currency"]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        @@media print {
            body { background: white !important; color: black !important; }
            .print-hide, header, footer, nav, .sidebar { display: none !important; }
            .card-dark, .table-dark { background: white !important; color: black !important; }
            .text-neon, .text-success, .text-warning, .text-info { color: black !important; }
            table { border-collapse: collapse; width: 100%; }
            th, td { border: 1px solid #ddd !important; }
        }
    </style>
}