@using SportComplexApp.Web.ViewModels.Report
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<SportReportViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="d-flex align-items-center justify-content-between mb-4 print-hide">
    <h2 class="mb-0" style="color:#00ffc8;">
        <i class="bi bi-activity me-2"></i>@Localizer["Heading"]
    </h2>
    <div class="d-flex gap-2">
        <button onclick="window.print()" class="btn btn-outline-neon">
            <i class="bi bi-printer me-1"></i> @Localizer["BtnPrint"]
        </button>
        <a asp-action="ExportSportReservationsCsv" 
           asp-route-startDate="@ViewData["StartDate"]" 
           asp-route-endDate="@ViewData["EndDate"]" 
           class="btn btn-neon">
            <i class="bi bi-filetype-csv me-1"></i> @Localizer["BtnExport"]
        </a>
    </div>
</div>

<div class="card card-dark border-0 shadow-sm mb-4 print-hide rounded-4">
    <div class="card-body p-4">
        <form method="get" asp-action="SportReservations" class="row g-3 align-items-end">
            <div class="col-md-4">
                <label class="form-label text-neon">@Localizer["StartDateLabel"]</label>
                <input type="date" name="startDate" class="form-control bg-dark text-light border-secondary" value="@ViewData["StartDate"]" />
            </div>
            <div class="col-md-4">
                <label class="form-label text-neon">@Localizer["EndDateLabel"]</label>
                <input type="date" name="endDate" class="form-control bg-dark text-light border-secondary" value="@ViewData["EndDate"]" />
            </div>
            <div class="col-md-4 d-flex gap-2">
                <button type="submit" class="btn btn-outline-neon w-50">
                    <i class="bi bi-search me-1"></i> @Localizer["BtnFilter"]
                </button>
                <a asp-action="SportReservations" class="btn btn-outline-secondary w-50">@Localizer["BtnClear"]</a>
            </div>
        </form>
    </div>
</div>

<div class="card card-dark border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-dark table-hover table-borderless align-middle mb-0 text-center">
                <thead style="border-bottom: 2px solid #00ffc8;">
                    <tr>
                        <th scope="col" class="text-start ps-4 py-3">@Localizer["ColClient"]</th>
                        <th scope="col" class="py-3">@Localizer["ColSport"]</th>
                        <th scope="col" class="py-3">@Localizer["ColDate"]</th>
                        <th scope="col" class="text-end pe-4 py-3">@Localizer["ColPrice"]</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-light-50">
                                @Localizer["EmptyData"]
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var res in Model)
                        {
                            <tr>
                                <td class="text-start ps-4 py-3 fw-bold text-light">
                                    <i class="bi bi-person me-2 text-muted"></i>@res.ClientName
                                </td>
                                <td class="py-3 text-info">
                                    @res.SportName
                                    @if (res.IsSportDeleted)
                                    {
                                        <span class="badge bg-danger ms-1 px-2 py-1 rounded-pill" style="font-size: 10px;">@Localizer["BadgeDeletedSport"]</span>
                                    }
                                </td>
                                <td class="py-3 text-light-50">@res.Date</td>
                                <td class="text-end pe-4 py-3 text-success fw-bold">
                                    @res.Price.ToString("F2") @Localizer["Currency"]
                                </td>
                            </tr>
                        }
                        
                        <tr style="border-top: 1px solid rgba(255,255,255,0.1);">
                            <td colspan="3" class="text-end py-3 text-neon fw-bold pe-3">@Localizer["TotalLabel"]:</td>
                            <td class="text-end pe-4 py-3 text-success fw-bold fs-5">
                                @Model.Sum(x => x.Price).ToString("F2") @Localizer["Currency"]
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
    <style>
        .text-light-50 { color: rgba(255,255,255,.5) !important; }
        @@media print {
            body { background: white !important; color: black !important; }
            .print-hide, header, footer, nav, .sidebar { display: none !important; }
            .card-dark, .table-dark { background: white !important; color: black !important; }
            .text-neon, .text-success, .text-warning, .text-info { color: black !important; }
            table { border-collapse: collapse; width: 100%; }
            th, td { border: 1px solid #ddd !important; }
        }
    </style>
}