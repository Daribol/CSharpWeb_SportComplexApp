@using SportComplexApp.Web.ViewModels.Sport
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model IEnumerable<AllSportsViewModel>

@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="d-flex align-items-center justify-content-between mb-4">
    <h2 class="mb-0" style="color:#00ffc8;">@Localizer["Heading"]</h2>
    <a asp-action="Add" class="btn btn-neon">
        <i class="bi bi-plus-circle"></i> @Localizer["BtnAddNewSport"]
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<form method="get" asp-action="All" class="mb-4">
    <div class="row g-3 align-items-end">
        <div class="col-md-3">
            <label for="searchQuery" class="form-label text-light">@Localizer["LabelSearchName"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-search"></i></span>
                <input type="text" name="searchQuery" id="searchQuery" class="form-control" placeholder="@Localizer["PlaceholderSearch"]" value="@Context.Request.Query["searchQuery"]" />
            </div>
        </div>

        <div class="col-md-2">
            <label for="minDuration" class="form-label text-light">@Localizer["LabelMinDuration"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-hourglass-split"></i></span>
                <input type="number" name="minDuration" id="minDuration" class="form-control" value="@Context.Request.Query["minDuration"]" />
            </div>
        </div>

        <div class="col-md-2">
            <label for="maxDuration" class="form-label text-light">@Localizer["LabelMaxDuration"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-hourglass"></i></span>
                <input type="number" name="maxDuration" id="maxDuration" class="form-control" value="@Context.Request.Query["maxDuration"]" />
            </div>
        </div>

        <div class="col-md-3">
            <label for="sortBy" class="form-label text-light">@Localizer["LabelSortBy"]</label>
            <div class="input-group neon-input">
                <span class="input-group-text neon-icon"><i class="bi bi-sort-down"></i></span>
                <select name="sortBy" id="sortBy" class="form-select">
                    <option value="">@Localizer["SortDefault"]</option>
                    <option value="name_asc" selected="@(Context.Request.Query["sortBy"] == "name_asc")">@Localizer["SortNameAsc"]</option>
                    <option value="name_desc" selected="@(Context.Request.Query["sortBy"] == "name_desc")">@Localizer["SortNameDesc"]</option>
                    <option value="duration_asc" selected="@(Context.Request.Query["sortBy"] == "duration_asc")">@Localizer["SortDurationAsc"]</option>
                    <option value="duration_desc" selected="@(Context.Request.Query["sortBy"] == "duration_desc")">@Localizer["SortDurationDesc"]</option>
                </select>
            </div>
        </div>

        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-outline-neon">
                <i class="bi bi-funnel-fill"></i> @Localizer["BtnFilter"]
            </button>
        </div>
    </div>

    <div class="mt-2 d-flex justify-content-end">
        <a asp-action="All" class="btn btn-outline-neon btn-sm">
            <i class="bi bi-x-circle"></i> @Localizer["BtnClear"]
        </a>
    </div>
</form>

@if (!Model.Any())
{
    <div class="card card-dark text-center p-5 rounded-4 border-0">
        <div class="display-6 mb-2">🏀</div>
        <h5 class="mb-1 text-light">@Localizer["NoSportsTitle"]</h5>
        <p class="text-light-50 mb-3">@Localizer["NoSportsDesc"]</p>
        <a asp-action="Add" class="btn btn-neon">
            <i class="bi bi-plus-circle"></i> @Localizer["BtnAddSport"]
        </a>
    </div>
}
else
{
    <div class="row g-4 row-cols-1 row-cols-sm-2 row-cols-lg-3 row-cols-xl-4">
        @foreach (var sport in Model)
        {
            <div class="col">
                <div class="card card-dark hover h-100 border-0">
                    @if (!string.IsNullOrWhiteSpace(sport.ImageUrl))
                    {
                        <div class="cover ratio ratio-16x9" style="background-image:url('@sport.ImageUrl');"></div>
                    }
                    else
                    {
                        <div class="cover cover--placeholder ratio ratio-16x9 d-flex align-items-center justify-content-center">
                            <i class="bi bi-image display-6 text-light-50"></i>
                        </div>
                    }

                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-2 text-white">@sport.Name</h5>

                        <ul class="list-unstyled small text-muted mb-3">
                            <li><i class="bi bi-cash-coin text-success"></i> @sport.Price.ToString("F2") @Localizer["Currency"]</li>
                            <li><i class="bi bi-stopwatch text-primary"></i> @sport.Duration @Localizer["Minutes"]</li>
                            <li><i class="bi bi-building text-warning"></i> @sport.Facility</li>
                        </ul>

                        <div class="mt-auto d-flex gap-2">
                            <a asp-action="Edit" asp-route-id="@sport.Id" class="btn btn-outline-neon btn-sm">
                                <i class="bi bi-pencil-square"></i> @Localizer["BtnEdit"]
                            </a>
                            <a asp-action="Delete" asp-route-id="@sport.Id" class="btn btn-outline-neon btn-sm">
                                <i class="bi bi-trash3"></i> @Localizer["BtnDelete"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
}