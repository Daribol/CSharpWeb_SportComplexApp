@model IEnumerable<FacilityMasterViewModel>
@using Microsoft.AspNetCore.Mvc.Localization
@using SportComplexApp.Web.ViewModels.Facility
@inject IViewLocalizer Localizer

<div class="container mt-4">
    <div class="d-flex align-items-center justify-content-between mb-4">
        <h2 class="mb-0" style="color:#00ffc8;">@Localizer["ManageFacilitiesHeader"]</h2>
        <a asp-action="Add" class="btn btn-neon">
            <i class="bi bi-plus-circle me-1"></i> @Localizer["BtnAddFacility"]
        </a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="card card-dark text-center p-5 rounded-4 border-0 shadow-lg">
            <div class="display-6 mb-2">🏢</div>
            <h5 class="mb-1 text-light">@Localizer["NoSportsAvailable"]</h5>
            <a asp-action="Add" class="btn btn-outline-neon mt-3">
                <i class="bi bi-plus-circle me-1"></i> @Localizer["BtnAddFacility"]
            </a>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var facility in Model)
            {
                var hasImg = !string.IsNullOrWhiteSpace(facility.ImageUrl);

                <div class="col">
                    <div class="card card-dark hover h-100 border-0 rounded-4 shadow-lg">
                        
                        @if (hasImg)
                        {
                            <img src="@facility.ImageUrl" class="card-img-top" alt="@facility.Name" style="height: 200px; object-fit: cover; border-radius: 1rem 1rem 0 0;" />
                        }
                        else
                        {
                            <div class="cover cover--placeholder d-flex align-items-center justify-content-center bg-dark border-bottom border-secondary border-opacity-25" style="height: 200px; border-radius: 1rem 1rem 0 0;">
                                <i class="bi bi-building display-1 text-light-50"></i>
                            </div>
                        }

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex align-items-start justify-content-between mb-3">
                                <h5 class="card-title text-white mb-0">@facility.Name</h5>
                                <span class="badge sc-badge-soft" title="@Localizer["ColumnSportsCount"]">
                                    <i class="bi bi-dribbble me-1"></i> @facility.Sports.Count()
                                </span>
                            </div>

                            <div class="mb-4">
                                <h6 class="text-light-50 small mb-2">
                                    <i class="bi bi-info-circle me-1"></i> @Localizer["SportsInHeader"]
                                </h6>
                                @if (facility.Sports.Any())
                                {
                                    <div class="d-flex flex-wrap gap-1">
                                        @foreach (var sport in facility.Sports)
                                        {
                                            <span class="badge badge-sport">@sport.SportName</span>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="text-muted small fst-italic">@Localizer["NoSportsAvailable"]</div>
                                }
                            </div>

                            <div class="d-flex gap-2 mt-3">
                                <a asp-action="Edit" asp-route-id="@facility.Id" class="btn btn-outline-neon btn-sm w-50">
                                    <i class="bi bi-pencil me-1"></i> @Localizer["BtnEdit"]
                                </a>
    
                                <a asp-action="Delete" asp-route-id="@facility.Id" class="btn btn-outline-danger btn-sm w-50">
                                    <i class="bi bi-trash me-1"></i> @Localizer["BtnDelete"]
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (ViewBag.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-5 mb-4">
        <ul class="pagination sc-pagination justify-content-center gap-2">
            
            <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                    <i class="bi bi-chevron-left small me-1"></i> @Localizer["Previous"]
                </a>
            </li>

            @for (int i = 1; i <= ViewBag.TotalPages; i++)
            {
                <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                    <a class="page-link rounded-circle shadow-sm d-flex align-items-center justify-content-center"
                           style="width: 40px; height: 40px;"
                           asp-action="All"
                           asp-route-page="@i">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                <a class="page-link rounded-pill px-3 shadow-sm bg-dark text-light border-secondary"
                       asp-action="All"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                    @Localizer["Next"] <i class="bi bi-chevron-right small ms-1"></i>
                </a>
            </li>
            
        </ul>
    </nav>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css">
}