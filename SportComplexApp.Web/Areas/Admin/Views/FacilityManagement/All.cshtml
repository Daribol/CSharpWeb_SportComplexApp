@model IEnumerable<FacilityMasterViewModel>
@using Microsoft.AspNetCore.Mvc.Localization
@using SportComplexApp.Web.ViewModels.Facility
@inject IViewLocalizer Localizer

<div class="container mt-5">
    <h2 class="mb-4 text-center" style="color:#00ffc8;">@Localizer["ManageFacilitiesHeader"]</h2>

    <div class="table-responsive shadow-sm">
        <table class="table align-middle mb-0 sc-table" style="border-collapse: collapse;">
            <thead>
                <tr>
                    <th style="width: 50px;"></th>
                    <th>@Localizer["ColumnFacilityName"]</th>
                    <th>@Localizer["ColumnSportsCount"]</th>
                    <th class="text-center">@Localizer["ColumnActions"]</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var facility in Model)
                {
                    <tr data-bs-toggle="collapse" data-bs-target="#details-@facility.Id" aria-expanded="false" style="cursor: pointer;">
                        <td class="text-center text-info">
                            <i class="bi bi-chevron-down"></i>
                        </td>
                        <td class="fw-semibold">@facility.Name</td>
                        <td><span class="badge sc-badge-soft">@facility.Sports.Count()</span></td>
                        <td class="text-center">
                            <a href="#" class="btn btn-sm btn-outline-neon">@Localizer["ButtonEdit"]</a>
                        </td>
                    </tr>

                    <tr id="details-@facility.Id" class="collapse" style="background-color: #0a0a0a;">
                        <td colspan="4" class="p-4 border-bottom border-info">
                            
                            <h6 class="text-muted mb-3">
                                <i class="bi bi-info-circle me-2"></i>
                                @Localizer["SportsInHeader"] @facility.Name
                            </h6>
                            
                            @if (facility.Sports.Any())
                            {
                                <table class="table table-sm table-dark table-borderless mb-0 w-50 mx-auto" style="border-radius: 8px; overflow: hidden;">
                                    <thead style="background: rgba(0, 255, 200, 0.1);">
                                        <tr>
                                            <th class="text-center">@Localizer["ColumnOfferedSport"]</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var sport in facility.Sports)
                                        {
                                            <tr>
                                                <td class="text-center">@sport.SportName</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            }
                            else
                            {
                                <div class="text-center text-muted my-2">@Localizer["NoSportsAvailable"]</div>
                            }

                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <style>
        tr[data-bs-toggle="collapse"] i.bi-chevron-down {
            transition: transform 0.3s ease;
            display: inline-block;
        }

        tr[data-bs-toggle="collapse"][aria-expanded="true"] i.bi-chevron-down {
            transform: rotate(180deg);
        }
    </style>
}