@page
@model LoginModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["Title"];
}

<div class="container d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card card-dark shadow-lg p-4 rounded-4" style="width: 100%; max-width: 400px;">
        <div class="text-center mb-4">
            <i class="bi bi-person-circle" style="font-size: 4rem; color: #00ffc8;"></i>
            <h2 class="mt-2" style="color:#00ffc8;">@Localizer["Title"]</h2>
            <p class="text-muted">@Localizer["WelcomeMsg"]</p>
        </div>

        <form id="account" method="post" novalidate>
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control neon-input" placeholder="name@example.com" />
                <label class="text-light">@Localizer["EmailLabel"]</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" type="password" class="form-control neon-input" placeholder="password" />
                <label class="text-light">@Localizer["PasswordLabel"]</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-neon w-100 btn-lg rounded-pill">@Localizer["LoginBtn"]</button>
        </form>

        <div class="text-center mt-4">
            <small class="text-muted">@Localizer["NoAccount"]</small>
            <a asp-page="./Register" class="ms-1 text-decoration-none" style="color:#00ffc8;">@Localizer["SignUp"]</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}